# ─── Mediflow Backend — Production Environment Variables ───────────────────────
# Copy this file to .env on your server and fill in real values.
# NEVER commit .env to version control.

# Required: Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE_ME_generate_a_64_char_random_key

# Must be False in production
DEBUG=False

# Django settings module (production)
DJANGO_SETTINGS_MODULE=mediflow.settings.prod

# Comma-separated list of allowed hostnames/IPs
# Example: ALLOWED_HOSTS=yourdomain.com,182.70.63.4
ALLOWED_HOSTS=your-domain-or-ip

# PostgreSQL — match docker-compose.yml service credentials
DATABASE_URL=postgres://mediflow:STRONG_DB_PASSWORD@postgres:5432/mediflow

# Redis
REDIS_URL=redis://redis:6379/0

# Your production frontend URL (used for CORS)
CORS_ALLOWED_ORIGINS=https://your-domain.com
