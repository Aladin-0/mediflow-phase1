# ─── Mediflow Frontend — Production Environment Variables ──────────────────────
# Copy this file to .env on your server and fill in real values.
# NEVER commit .env or .env.local to version control.

# Your production backend API URL (no trailing slash)
# The Docker nginx proxy routes /api/ internally, so use your domain:
NEXT_PUBLIC_API_URL=https://your-domain.com/api/v1

# App metadata
NEXT_PUBLIC_APP_NAME=Manavata Pharma
NEXT_PUBLIC_APP_VERSION=1.0.0
NEXT_PUBLIC_USE_MOCK=false
